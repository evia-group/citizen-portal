{
  "name": "user-portal-fe",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "npm run web",
    "android": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 expo start --android",
    "ios": "expo start --ios",
    "web": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 expo start --web",
    "e2e:web": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 EXPO_NO_HMR_OVERLAY=1 expo start --web",
    "test": "jest --watchAll",
    "lint": "npx expo customize tsconfig.json && tsc --noEmit",
    "lint:full": "npx -y expo-doctor && npx expo customize tsconfig.json && tsc --noEmit",
    "build:web": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 expo export -p web",
    "build-app": "npm run build:ios",
    "build-app:ios": "eas build -p ios --profile preview"
  },
  "jest": {
    "preset": "jest-expo",
    "roots": [
      "<rootDir>",
      "<rootDir>/../../libs/shared-fe"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|ky)"
    ]
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-gesture-handler",
        "jest-expo"
      ]
    }
  },
  "dependencies": {
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-native-community/netinfo": "11.1.0",
    "@react-native-picker/picker": "2.6.1",
    "@react-navigation/native": "^6.0.2",
    "@repo/auth": "*",
    "@repo/mailbox": "*",
    "@repo/profile": "*",
    "@repo/services": "*",
    "@repo/documents": "*",
    "@repo/shared": "*",
    "@repo/tailwind-config": "*",
    "@repo/ui": "*",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-query-devtools": "^5.100.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~50.0.19",
    "expo-auth-session": "^5.4.0",
    "expo-font": "~11.10.2",
    "expo-linear-gradient": "~12.7.2",
    "expo-linking": "~6.2.2",
    "expo-router": "~3.4.10",
    "expo-splash-screen": "~0.26.5",
    "expo-status-bar": "~1.11.1",
    "expo-system-ui": "~2.9.4",
    "expo-web-browser": "~12.8.2",
    "lucide-react-native": "^0.577.0",
    "nativewind": "^4.0.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "~7.54.2",
    "react-native": "0.73.6",
    "react-native-gesture-handler": "2.15.0",
    "react-native-picker-select": "^9.0.1",
    "react-native-reanimated": "~3.6.2",
    "react-native-reanimated-carousel": "^4.0.0-alpha.9",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "react-native-svg": "14.1.0",
    "react-native-web": "~0.19.6",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "expo-secure-store": "~12.8.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.45",
    "babel-preset-expo": "^10.0.1",
    "cross-env": "^7.0.3",
    "jest": "^29.2.1",
    "jest-expo": "~50.0.2",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.9.3"
  }
}
