{
  "name": "user-portal-fe",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "npm run web",
    "android": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 expo start --android",
    "ios": "expo start --ios",
    "web": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 expo start --web",
    "e2e:web": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 EXPO_NO_HMR_OVERLAY=1 expo start --web",
    "test": "jest --watchAll",
    "lint": "npx expo customize tsconfig.json && tsc --noEmit",
    "lint:full": "npx -y expo-doctor && npx expo customize tsconfig.json && tsc --noEmit",
    "build:web": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 expo export -p web",
    "build-app": "npm run build:ios",
    "build-app:ios": "eas build -p ios --profile preview"
  },
  "jest": {
    "preset": "jest-expo",
    "roots": [
      "<rootDir>",
      "<rootDir>/../../libs/shared-fe"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|ky)"
    ]
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-gesture-handler",
        "jest-expo"
      ]
    }
  },
  "dependencies": {
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-picker/picker": "2.9.0",
    "@react-navigation/native": "^7.0.14",
    "@repo/auth": "*",
    "@repo/documents": "*",
    "@repo/mailbox": "*",
    "@repo/profile": "*",
    "@repo/services": "*",
    "@repo/shared": "*",
    "@repo/tailwind-config": "*",
    "@repo/ui": "*",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-query-devtools": "^5.100.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~52.0.49",
    "expo-auth-session": "~6.0.3",
    "expo-font": "~13.0.4",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.5",
    "expo-router": "~4.0.22",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.1",
    "expo-system-ui": "~4.0.9",
    "expo-web-browser": "~14.0.2",
    "lucide-react-native": "^0.577.0",
    "nativewind": "^4.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "~7.54.2",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~18.3.12",
    "babel-preset-expo": "~12.0.12",
    "cross-env": "^7.0.3",
    "jest": "^29.2.1",
    "jest-expo": "~52.0.6",
    "react-test-renderer": "18.3.1",
    "typescript": "^5.9.3"
  }
}
