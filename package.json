{
  "name": "portal-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:user-portal": "turbo run dev --filter=user-portal-fe...",
    "dev:service-portal": "turbo run dev --filter=service-portal-fe...",
    "dev:admin-portal": "turbo run dev --filter=admin-portal-fe...",
    "dev:local": "npx --yes concurrently -n be,fe -c blue,green \"cd apps/user-portal-be && mvn spring-boot:run -Dspring-boot.run.arguments=--server.port=8180\" \"npm run dev:user-portal\"",
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules",
    "lint": "biome check ./apps/*-fe ./libs && turbo run lint",
    "format": "biome format ./apps/*-fe ./libs --write",
    "fix": "biome check ./apps/*-fe ./libs --write"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "concurrently": "^9.0.0",
    "eslint": "^9.39.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-reanimated": "~3.17.4",
    "react-native-svg": "15.2.0",
    "turbo": "^1.13.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*-fe",
    "libs/*-fe",
    "libs/auth",
    "libs/mailbox",
    "libs/mock-server",
    "libs/profile",
    "libs/services",
    "libs/documents",
    "libs/applications",
    "libs/eslint-config",
    "libs/tailwind-config",
    "libs/typescript-config",
    "libs/ui"
  ],
  "overrides": {
    "@types/react": "19.0.14",
    "@types/react-dom": "19.0.6",
    "nativewind": "4.2.4",
    "react-native": "0.79.6",
    "react-native-css-interop": "0.2.4",
    "react-native-reanimated": "~3.17.4"
  }
}
