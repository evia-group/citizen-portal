.turbo
infrastructure/dms/

# e2e run artifacts (loose screenshots + playwright cache; tracked baselines stay)
e2e/*/screenshots/*
!e2e/*/screenshots/baseline/
e2e/*/.playwright-cli/
e2e/*/.playwright/

# Local agent scratch (screenshots, traces, ad-hoc artifacts)
.scratch/

# AI coding agents — local/per-user state (instructions live in AGENTS.md;
# shared plans live in .junie/plans/)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.aider*
.cursor/
.codex/
/.claude/plans/

# devcontainer local proxy config (real values, never commit)
.devcontainer/devcontainer.env
.devcontainer/_devcontainer.json
