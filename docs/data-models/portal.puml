@startuml

!theme plain
top to bottom direction
skinparam linetype ortho

class portal_application {
   version: numeric(38)
   status: varchar(50)
   profile_id: bigint
   created_date: date
   updated_date: date
   service_id: bigint
   id: bigint
}
class portal_category {
   version: numeric(38)
   name: varchar(255)
   icon: varchar(255)
   slug: varchar(255)
   domain_id: bigint
   id: bigint
}
class portal_comment {
   version: numeric(38)
   content: varchar(255)
   parent_comment_id: bigint
   created_date: date
   updated_date: date
   profile_id: bigint
   application_id: bigint
   id: bigint
}
class portal_consent {
   version: numeric(38)
   name: varchar(255)
   text: varchar(255)
   service_id: bigint
   id: bigint
}
class portal_consent_log {
   version: numeric(38)
   status: varchar(255)
   consent_text: varchar(255)
   accepted_at: timestamp with time zone
   consent_id: bigint
   profile_id: bigint
   id: bigint
}
class portal_document {
   version: numeric(38)
   name: varchar(255)
   is_archive: boolean
   type: varchar(50)
   id: bigint
}
class portal_dog {
   version: numeric(38)
   race: varchar(255)
   name: varchar(255)
   tax_stamp_number: varchar(255)
   relationship_id: bigint
   id: bigint
}
class portal_dog_application {
   version: numeric(38)
   justification: varchar(255)
   application_id: bigint
   dog_id: bigint
   id: bigint
}
class portal_domain {
   version: numeric(38)
   name: varchar(255)
   icon: varchar(255)
   slug: varchar(255)
   id: bigint
}
class portal_location {
   version: numeric(38)
   name: varchar(255)
   federal_state: varchar(255)
   id: bigint
}
class portal_notification {
   version: numeric(38)
   message: varchar(255)
   subject: varchar(255)
   status: varchar(255)
   source: varchar(255)
   profile_id: bigint
   created_date: date
   id: bigint
}
class portal_profile {
   version: numeric(38)
   gender: varchar(255)
   grade: varchar(255)
   first_name: varchar(255)
   last_name: varchar(255)
   birth_name: varchar(255)
   birth_date: date
   birth_location: varchar(255)
   can_notify_by_mail: boolean
   can_notify_by_sms: boolean
   zip_code: varchar(255)
   city: varchar(255)
   country: varchar(255)
   street: varchar(255)
   house_number: bigint
   phone_number: varchar(255)
   email: varchar(255)
   de_mail: varchar(255)
   location_id: bigint
   account_owner: varchar(255)
   iban: varchar(22)
   bic: varchar(11)
   tax_id: varchar(11)
   id: bigint
}
class portal_relationship {
   version: numeric(38)
   type: varchar(255)
   name: varchar(255)
   profile_id: bigint
   id: bigint
}
class portal_service {
   version: numeric(19)
   name: varchar(255)
   icon: varchar(255)
   slug: varchar(255)
   cost: bigint
   location_id: bigint
   category_id: bigint
   id: bigint
}
class portal_user {
   version: numeric(38)
   name: varchar(255)
   id: bigint
}

portal_application      -[#595959,plain]-^  portal_profile         : "profile_id:id"
portal_application      -[#595959,plain]-^  portal_service         : "service_id:id"
portal_category         -[#595959,plain]-^  portal_domain          : "domain_id:id"
portal_comment          -[#595959,plain]-^  portal_application     : "application_id:id"
portal_comment          -[#595959,plain]-^  portal_profile         : "profile_id:id"
portal_consent          -[#595959,plain]-^  portal_service         : "service_id:id"
portal_consent_log      -[#595959,plain]-^  portal_consent         : "consent_id:id"
portal_consent_log      -[#595959,plain]-^  portal_profile         : "profile_id:id"
portal_dog              -[#595959,plain]-^  portal_profile         : "relationship_id:id"
portal_dog_application  -[#595959,plain]-^  portal_application     : "application_id:id"
portal_dog_application  -[#595959,plain]-^  portal_dog             : "dog_id:id"
portal_notification     -[#595959,plain]-^  portal_profile         : "profile_id:id"
portal_profile          -[#595959,plain]-^  portal_location        : "location_id:id"
portal_relationship     -[#595959,plain]-^  portal_profile         : "profile_id:id"
portal_service          -[#595959,plain]-^  portal_category        : "category_id:id"
portal_service          -[#595959,plain]-^  portal_location        : "location_id:id"
@enduml
