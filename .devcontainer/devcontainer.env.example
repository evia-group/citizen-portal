# Local proxy config for the devcontainer — copy to .devcontainer/devcontainer.env
# (gitignored) and fill in. Injected at container start via runArgs --env-file.
#
# Default (all empty) = no proxy. With HTTP_PROXY set, setup-proxy.sh derives
# HTTPS_PROXY + lowercase variants (~/.proxy.env, sourced by ~/.bashrc) and generates
# ~/.m2/settings.xml — so only these three canonical values are ever maintained.
#
# NOTE (docker --env-file syntax): no quotes around values, no spaces around '=' —
# quotes would become part of the value.

# Proxy URL, e.g. http://proxy.example.de:3128
HTTP_PROXY=
# Comma-separated, leading-dot suffixes, e.g. localhost,127.0.0.1,.example.de,10.*
NO_PROXY=localhost,127.0.0.1
# Picked up by EVERY JVM, incl. the mvnw wrapper's distribution download (which
# ignores proxy env vars). Java syntax: '|' separators, '*.' wildcards, e.g.
#   -Dhttp.proxyHost=proxy.example.de -Dhttp.proxyPort=3128 -Dhttps.proxyHost=proxy.example.de -Dhttps.proxyPort=3128 -Dhttp.nonProxyHosts=localhost|127.0.0.1|*.example.de|10.*
JAVA_TOOL_OPTIONS=
