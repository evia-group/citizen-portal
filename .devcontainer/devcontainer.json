{
  "name": "Citizen Portal — Junie sandbox",
  // Build-time proxy: runArgs --env-file does NOT apply to image builds, so build
  // args resolve from the HOST environment. Export the vars on the host first, e.g.
  //   set -a; source .devcontainer/devcontainer.env; set +a
  // before launching, or configure "proxies" in ~/.docker/config.json instead (Docker
  // then injects them into every build/run automatically). On a proxy-less host the
  // unset vars resolve to "" — curl/apt treat empty as "no proxy".
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "HTTP_PROXY": "${localEnv:HTTP_PROXY}",
      "HTTPS_PROXY": "${localEnv:HTTPS_PROXY}",
      "NO_PROXY": "${localEnv:NO_PROXY}",
      "http_proxy": "${localEnv:http_proxy}",
      "https_proxy": "${localEnv:https_proxy}",
      "no_proxy": "${localEnv:no_proxy}"
    }
  },
  "remoteUser": "vscode",

  // Runtime proxy config lives in .devcontainer/devcontainer.env — gitignored so the
  // real proxy host never lands in git; optional and missing/empty = proxy-less
  // default. It holds only three canonical values (HTTP_PROXY, NO_PROXY,
  // JAVA_TOOL_OPTIONS — every JVM incl. the mvnw wrapper download reads the latter).
  // setup-proxy.sh reads it INSIDE the container at postCreate (no initializeCommand /
  // runArgs: host-side lifecycle commands run via `sh`, which breaks on Windows hosts,
  // and --env-file fails when the file is absent) and derives ~/.proxy.env (exports,
  // sourced by ~/.bashrc) plus ~/.m2/settings.xml (Maven resolution ignores env vars).

  // Pin JAVA_HOME to the JDK shipped in mcr.microsoft.com/devcontainers/java:1-21-bookworm
  // (Microsoft Build of OpenJDK — confirmed via `docker run ... echo $JAVA_HOME`) so a host
  // JAVA_HOME can't leak in and break `./mvnw` ("JAVA_HOME is not defined correctly").
  // containerEnv applies to every process incl. postCreateCommand.
  "containerEnv": {
    "JAVA_HOME": "/usr/lib/jvm/msopenjdk-current"
  },

  // Node 22 via the official feature (matches .node-version v22.11.0, engines.node >=22).
  // Kept out of the Dockerfile so the image stays simple and cross-platform.
  "features": {
    "ghcr.io/devcontainers/features/node:2": {
      "version": "22"
    }
  },

  // Persist Junie auth + dependency caches as named volumes so they survive rebuilds.
  // Nothing secret is committed to the repo; the one-time /account login lives in ~/.junie.
  "mounts": [
    "source=citizen-portal-junie,target=/home/vscode/.junie,type=volume",
    "source=citizen-portal-m2,target=/home/vscode/.m2,type=volume",
    "source=citizen-portal-npm,target=/home/vscode/.npm,type=volume"
  ],

  // Named volumes mount root-owned, so the non-root `vscode` user can't write into
  // ~/.junie, ~/.m2, or ~/.npm (Junie's logs/, Maven's wrapper/ → AccessDeniedException).
  // chown them once after mount, generate the Maven proxy config from env, then warm
  // the dependency caches. Tolerant of failure (|| true) so the container still comes
  // up if the network hiccups; honors .npmrc legacy-peer-deps.
  "postCreateCommand": "sudo chown -R vscode:vscode /home/vscode/.junie /home/vscode/.m2 /home/vscode/.npm; bash .devcontainer/setup-proxy.sh; . $HOME/.proxy.env; npm install || true; ./mvnw -q -DskipTests dependency:go-offline || true",

  // The Junie /account login opens a localhost OAuth callback. Auto-forwarding can remap
  // the container port to a different host port, which breaks the loopback redirect_uri
  // ("invalid_grant / Redirect URI mismatch" at token exchange). Pin 62345 so the host
  // forwards it 1:1 to the container — the redirect_uri then matches byte-for-byte.
  // Junie must use this same port for the handshake (e.g. start it as `junie` after
  // confirming the printed callback URL reads http://localhost:62345).
  "forwardPorts": [62345],
  "portsAttributes": {
    "62345": {
      "label": "Junie auth callback",
      "onAutoForward": "silent"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": []
    }
  }
}
