USER_NAME=user
USER_PASSWORD=user

# Target URLs (KC/API/APP) are derived per environment in commons.sh / forwards.sh:
#   - devcontainer (Mode A): served through the gateway, reached via socat localhost forwards
#   - host (Mode B): native FE on :8081, infra in Docker
# Detection: E2E_IN_DEVCONTAINER=1 marker; override with E2E_ENV=devcontainer|host,
# or set KC/API/APP explicitly before sourcing commons.sh.
